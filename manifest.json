{
  "manifest_version": 3,
  "name": "Quick Link Copier",
  "version": "1.0",
  "description": "Hover a link and press Ctrl+M to copy it instantly",
  "permissions": ["clipboardWrite"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["styles.css"]
    }
  ]
}
